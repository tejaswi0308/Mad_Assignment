<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="24px">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sensor Dashboard"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp"
            android:layout_marginTop="30px"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#1E1E1E">
            <LinearLayout android:padding="20dp" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:text="Accelerometer" android:textColor="#03DAC5" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                <TextView android:id="@+id/accelX" android:text="X: 0.0" android:textColor="#03DAC5" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                <TextView android:id="@+id/accelY" android:text="Y: 0.0" android:textColor="#03DAC5" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                <TextView android:id="@+id/accelZ" android:text="Z: 0.0" android:textColor="#03DAC5" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#1E1E1E">
            <LinearLayout android:padding="20dp" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:text="Light Sensor" android:textColor="#FFEB3B" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                <TextView android:id="@+id/lightValue" android:text="Brightness: 0 lx" android:textColor="#FFFFFF" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#1E1E1E">
            <LinearLayout android:padding="20dp" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
                <TextView android:text="Proximity Sensor" android:textColor="#BB86FC" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                <TextView android:id="@+id/proximityValue" android:text="Distance: 0 cm" android:textColor="#FFFFFF" android:layout_width="wrap_content" android:layout_height="wrap_content" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>